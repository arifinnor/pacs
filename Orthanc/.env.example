# PACS Environment Variables Template
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control

# ==============================================================================
# POSTGRESQL DATABASE
# ==============================================================================
# PostgreSQL password for the 'orthanc' user
# Requirements: Strong password, min 16 characters recommended
DB_PASSWORD=your_secure_postgres_password_here

# ==============================================================================
# ORTHANC ADMIN
# ==============================================================================
# Admin password for Orthanc web UI and REST API
# Requirements: Strong password, min 16 characters recommended
# This is for the 'admin' user configured in orthanc.json
ADMIN_PASSWORD=your_secure_admin_password_here

# ==============================================================================
# OPTIONAL: PRODUCTION OVERRIDES
# ==============================================================================
# The following values can be overridden if needed
# Default values are already set in docker-compose.yml

# Orthanc Application Entity Title (must match modality config)
# ORTHANC__DICOM_AET=ORTHANC

# DICOM port for receiving images from modalities
# ORTHANC__DICOM_PORT=4242

# HTTP port for Orthanc REST API (internal only, not exposed)
# ORTHANC__HTTP_PORT=8042

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
# 1. Use different passwords for DB_PASSWORD and ADMIN_PASSWORD
# 2. Never use these example passwords in production
# 3. Rotate passwords regularly (every 90 days recommended)
# 4. Store passwords securely in production (use secrets management)
# 5. For production, consider using Docker secrets instead of .env file

# ==============================================================================
# QUICK START (Development Only)
# ==============================================================================
# For local development, you can use simple passwords:
# DB_PASSWORD=dev_password_123
# ADMIN_PASSWORD=admin
#
# WARNING: These are NOT secure for production use!
